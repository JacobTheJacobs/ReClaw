{
  "name": "reclaw",
  "version": "1.0.0",
  "description": "OpenClaw Recover Backup & Restore - A simple command-line tool to back up and restore your entire OpenClaw configuration.",
  "main": "lib/index.js",
  "bin": {
    "reclaw": "bin/cli.js"
  },
  "scripts": {
    "test": "jest --runInBand",
    "test:integration:mac": "jest --runInBand test/openclaw.mac.integration.test.js",
    "test:integration:windows": "pwsh -File scripts/test-openclaw-recovery-windows.ps1",
    "test:verify-openclaw:mac": "jest --runInBand test/openclaw.mac.verify.test.js",
    "test:integration": "npm run test:integration:mac",
    "test:verify-openclaw": "npm run test:verify-openclaw:mac",
    "test:integration:docker": "RUN_DOCKER_TESTS=1 jest --runInBand test/openclaw.docker.integration.test.js test/openclaw.docker.backup-restore.test.js",
    "verify:empty": "node scripts/verify-openclaw-state.js empty",
    "verify:restored": "node scripts/verify-openclaw-state.js restored",
    "verify:health": "curl -fsS http://127.0.0.1:18789/healthz",
    "verify:health:node": "node scripts/verify-gateway-health.js",
    "verify:all": "npm run verify:restored && npm run verify:health",
    "gateway:url": "node scripts/ensure-gateway-token.js",
    "script:gateway:url": "node scripts/ensure-gateway-token.js",
    "dashboard:open": "node scripts/ensure-gateway-token.js --open",
    "script:dashboard:open": "node scripts/ensure-gateway-token.js --open",
    "desktop:open": "electron ./desktop-ui/main.js",
    "desktop:start": "electron ./desktop-ui/main.js",
    "desktop:wizard-test": "RECLAW_FORCE_SETUP_WIZARD=1 electron ./desktop-ui/main.js",
    "desktop:wizard-test:windows": "set RECLAW_FORCE_SETUP_WIZARD=1 && electron ./desktop-ui/main.js",
    "desktop:pack:dir": "electron-builder --config desktop-ui/electron-builder.json --dir",
    "desktop:pack:win": "electron-builder --config desktop-ui/electron-builder.json --win nsis --x64",
    "desktop:pack:portable": "electron-builder --config desktop-ui/electron-builder.json --win portable --x64",
    "desktop:pack:mac": "electron-builder --config desktop-ui/electron-builder.json --mac dmg zip --publish never",
    "desktop:setup:mac": "bash scripts/setup-mac-desktop.sh",
    "reset:local": "bash scripts/full-reset-openclaw.sh",
    "script:reset:local": "bash scripts/full-reset-openclaw.sh",
    "reset:windows": "pwsh -File scripts/full-reset-openclaw.ps1",
    "script:reset:windows": "pwsh -File scripts/full-reset-openclaw.ps1",
    "recover:local": "bash scripts/recover-openclaw-local-mac.sh",
    "script:recover:local": "bash scripts/recover-openclaw-local-mac.sh",
    "recover:windows": "pwsh -File scripts/recover-openclaw-local-windows.ps1",
    "script:recover:windows": "pwsh -File scripts/recover-openclaw-local-windows.ps1",
    "test:recovery:windows": "pwsh -File scripts/test-openclaw-recovery-windows.ps1",
    "drill:docker": "bash scripts/docker-recovery-drill.sh",
    "script:drill:docker": "bash scripts/docker-recovery-drill.sh",
    "script:install:mac": "bash scripts/install-mac.sh",
    "script:install:windows": "pwsh -File scripts/install-windows.ps1",
    "recover:flow": "npm run verify:empty && npm run recover:local && npm run verify:all",
    "recover:flow:windows": "npm run test:recovery:windows",
    "postinstall": "node scripts/postinstall-banner.js && node scripts/ensure-gateway-token.js",
    "backup": "node bin/cli.js backup",
    "backup:create": "node bin/cli.js backup create",
    "backup:verify": "node bin/cli.js backup verify",
    "backup:restore": "node bin/cli.js backup restore",
    "backup:list": "node bin/cli.js backup list",
    "backup:prune": "node bin/cli.js backup prune",
    "backup:export": "node bin/cli.js backup export",
    "backup:daily": "bash scripts/backup-openclaw-daily.sh",
    "backup:daily:windows": "pwsh -File scripts/backup-openclaw-daily.ps1",
    "restore": "node bin/cli.js restore",
    "openclaw:backup:create": "openclaw backup create",
    "openclaw:backup:create:verify": "openclaw backup create --verify",
    "openclaw:backup:create:plan": "openclaw backup create --dry-run --json",
    "openclaw:backup:create:only-config": "openclaw backup create --only-config",
    "openclaw:backup:create:no-workspace": "openclaw backup create --no-include-workspace",
    "openclaw:backup:verify": "openclaw backup verify",
    "openclaw:reset:safe": "openclaw reset --scope config+creds+sessions --yes --non-interactive",
    "openclaw:reset:dry-run": "openclaw reset --dry-run",
    "openclaw:doctor": "openclaw doctor",
    "openclaw:doctor:repair": "openclaw doctor --repair",
    "openclaw:doctor:repair:force": "openclaw doctor --repair --force",
    "openclaw:doctor:non-interactive": "openclaw doctor --non-interactive",
    "openclaw:doctor:deep": "openclaw doctor --deep",
    "openclaw:doctor:yes": "openclaw doctor --yes",
    "openclaw:doctor:token": "openclaw doctor --generate-gateway-token",
    "openclaw:doctor:fix": "openclaw doctor --fix",
    "openclaw:security": "openclaw security audit",
    "openclaw:security:deep": "openclaw security audit --deep",
    "openclaw:security:fix": "openclaw security audit --fix",
    "openclaw:security:json": "openclaw security audit --json",
    "openclaw:secrets:reload": "openclaw secrets reload",
    "openclaw:secrets:audit": "openclaw secrets audit",
    "openclaw:status": "openclaw status",
    "openclaw:status:deep": "openclaw status --deep",
    "openclaw:status:all": "openclaw status --all",
    "openclaw:status:usage": "openclaw status --usage",
    "openclaw:health": "openclaw health",
    "openclaw:health:json": "openclaw health --json",
    "openclaw:channels:status": "openclaw channels status",
    "openclaw:channels:status:probe": "openclaw channels status --probe",
    "openclaw:models:status": "openclaw models status",
    "openclaw:models:status:probe": "openclaw models status --probe",
    "openclaw:gateway:start": "openclaw gateway start",
    "openclaw:gateway:stop": "openclaw gateway stop",
    "openclaw:setup": "openclaw setup",
    "openclaw:gateway:status": "openclaw gateway status",
    "openclaw:gateway:status:deep": "openclaw gateway status --deep",
    "openclaw:gateway:restart": "openclaw gateway restart",
    "openclaw:gateway:install": "openclaw gateway install",
    "openclaw:gateway:uninstall": "openclaw gateway uninstall",
    "openclaw:logs:follow": "openclaw logs --follow",
    "start": "node bin/cli.js",
    "reclaw": "node bin/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JacobTheJacobs/ReClaw.git"
  },
  "keywords": [
    "openclaw",
    "backup",
    "restore",
    "recovery",
    "automation",
    "reclaw"
  ],
  "author": "JacobTheJacobs",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JacobTheJacobs/ReClaw/issues"
  },
  "homepage": "https://github.com/JacobTheJacobs/ReClaw#readme",
  "dependencies": {
    "adm-zip": "^0.5.10",
    "archiver": "^7.0.0",
    "archiver-zip-encrypted": "^1.0.11",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "jest": "^29.7.0"
  }
}
